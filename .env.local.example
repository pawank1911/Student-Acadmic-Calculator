# =============================================================
# Student Academic Calculator — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and NEVER committed to version control.

# =============================================================
# OPTIONAL: Real Google OAuth (leave blank for demo/simulated mode)
# =============================================================
# To enable real Google Sign-In:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web Application)
# 4. Add http://localhost:3000 to Authorized JavaScript Origins
# 5. Add http://localhost:3000 to Authorized redirect URIs
# 6. Paste the Client ID below

NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================
# Firebase web app configuration
# =============================================================
# Copy the values from Firebase Console > Project settings > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================
# App URL (used for sharing links)
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
